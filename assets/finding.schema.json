{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SaaS Audit Finding",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "status",
    "domain",
    "severity",
    "priority",
    "environment",
    "description",
    "expected",
    "actual",
    "reproduction",
    "risk",
    "evidence",
    "remediation",
    "retest"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[A-Z]+-[0-9]{3,}$"},
    "title": {"type": "string", "minLength": 5},
    "status": {
      "enum": [
        "CONFIRMED",
        "PROBABLE",
        "OBSERVATION",
        "BLOCKED",
        "FALSE_POSITIVE",
        "RETEST_PASS",
        "RETEST_FAIL"
      ]
    },
    "domain": {"type": "string"},
    "severity": {"enum": ["Critical", "High", "Medium", "Low", "Informational"]},
    "priority": {"enum": ["P0", "P1", "P2", "P3", "P4"]},
    "environment": {"type": "string"},
    "affected_roles": {"type": "array", "items": {"type": "string"}},
    "affected_tenants": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "expected": {"type": "string"},
    "actual": {"type": "string"},
    "reproduction": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "risk": {
      "type": "object",
      "required": ["likelihood", "technical_impact", "business_impact", "score", "summary"],
      "properties": {
        "likelihood": {"type": "integer", "minimum": 1, "maximum": 5},
        "technical_impact": {"type": "integer", "minimum": 1, "maximum": 5},
        "business_impact": {"type": "integer", "minimum": 1, "maximum": 5},
        "user_impact": {"type": "integer", "minimum": 1, "maximum": 5},
        "exploitability": {"type": "integer", "minimum": 1, "maximum": 5},
        "detectability": {"type": "integer", "minimum": 1, "maximum": 5},
        "score": {"type": "number", "minimum": 0, "maximum": 100},
        "summary": {"type": "string"}
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "reference"],
        "properties": {
          "type": {"type": "string"},
          "reference": {"type": "string"},
          "description": {"type": "string"},
          "redacted": {"type": "boolean"}
        }
      }
    },
    "root_cause": {"type": "string"},
    "remediation": {
      "type": "object",
      "required": ["immediate", "permanent", "validation"],
      "properties": {
        "immediate": {"type": "string"},
        "permanent": {"type": "string"},
        "validation": {"type": "array", "items": {"type": "string"}},
        "regression_test": {"type": "string"},
        "owner": {"type": "string"},
        "effort": {"enum": ["XS", "S", "M", "L", "XL"]},
        "target_release": {"type": "string"}
      }
    },
    "retest": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"enum": ["NOT_RETESTED", "PASS", "FAIL", "BLOCKED"]},
        "date": {"type": "string"},
        "evidence": {"type": "array", "items": {"type": "string"}},
        "residual_risk": {"type": "string"}
      }
    }
  }
}
